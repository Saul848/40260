<?xml version="1.0" encoding="UTF-8"?>
<proceso_ordeno id="vaca_001">
    
    <preparacion>
        <accion tipo="limpieza">
            <objetivo>ubres</objetivo>
            <solucion>agua_tibia</solucion>
        </accion>
        <accion tipo="masaje">
            <duracion unidad="segundos">30</duracion>
        </accion>
    </preparacion>

    <ejecucion metodo="manual">
        <herramienta>cubeta_aluminio</herramienta>
        <bucle repeticion="hasta_agotar">
            <movimiento tipo="presion_descendente">
                <intensidad nivel="medio" />
            </movimiento>
        </bucle>
    </ejecucion>

    <finalizacion>
        <accion tipo="sellado">
            <producto>antiseptico_post_ordeno</producto>
        </accion>
        <registro_datos>
            <litros_obtenidos />
        </registro_datos>
    </finalizacion>

</proceso_ordeno>

